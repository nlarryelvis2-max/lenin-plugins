{
  "name": "lenin",
  "owner": { "name": "lenin-ecosystem" },
  "metadata": {
    "description": "Публичный Lenin Client: личное ядро и безопасная синхронизация с приватной платформой",
    "version": "1.5.0"
  },
  "plugins": [
    {
      "name": "lenin-client",
      "displayName": "Lenin Client",
      "version": "0.3.0",
      "source": "./",
      "strict": false,
      "description": "Единый клиент Ленина для Claude Code: личное ядро, память и Uplink",
      "homepage": "https://lenin.nglain.com",
      "repository": "https://github.com/nlarryelvis2-max/lenin-plugins",
      "keywords": ["lenin", "client", "memory", "uplink", "project-context"],
      "commands": ["./client/commands/"],
      "skills": ["./lenin-core/skills/"],
      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/identity_context.py\" 2>/dev/null || true" },
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/session_gradient.py\" 2>/dev/null || true" },
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/posterior_health.py\" 2>/dev/null || true" },
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-uplink/scripts/session_uplink_check.py\" 2>/dev/null || true" }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "hooks": [
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/atom_swarm.py\" 2>/dev/null || true" },
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/slow_read_gate.py\" 2>/dev/null || true" },
              { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/lenin-core/hooks/verify_gate.py\" 2>/dev/null || true" }
            ]
          }
        ]
      }
    },
    {
      "name": "lenin-owner",
      "displayName": "Lenin Owner MCP",
      "version": "0.2.0",
      "source": "./owner",
      "strict": true,
      "description": "Отдельный административный MCP только для глобальных владельцев Ленина",
      "homepage": "https://lenin.nglain.com",
      "repository": "https://github.com/nlarryelvis2-max/lenin-plugins",
      "keywords": ["lenin", "owner", "admin", "mcp"],
      "commands": ["./commands/"]
    },
    {
      "name": "lenin-core",
      "source": "./lenin-core",
      "description": "Внутренний компонент Lenin Client: личное ядро, память и онбординг"
    },
    {
      "name": "lenin-uplink",
      "source": "./lenin-uplink",
      "description": "Внутренний компонент Lenin Client: безопасная синхронизация сессий по lenin-uplink/1"
    }
  ]
}
